# =========================================================
# MovAmazon - Environment Template (PRODUCTION SAFE EXAMPLE)
# =========================================================
# Nunca comite credenciais reais neste arquivo.
# Copie para .env no servidor e preencha com valores reais.

# -----------------------------
# Ambiente
# -----------------------------
APP_ENV=production
URL_BASE=https://movamazon.com.br
APP_URL=https://movamazon.com.br

# -----------------------------
# Banco de dados
# -----------------------------
DB_HOST=127.0.0.1
DB_NAME=movamazon
DB_USER=movamazon_user
DB_PASS=change_me_strong_password
# Opcional (usado em scripts de teste/integracao)
DB_PORT=3306

# -----------------------------
# Email / SMTP
# -----------------------------
SMTP_HOST=mail.seudominio.com.br
SMTP_USERNAME=noreply@seudominio.com.br
SMTP_PASSWORD=change_me_smtp_password
SMTP_PORT=465
# Valores comuns: ssl | tls | none
SMTP_SECURE=ssl
# Alias opcional aceito pelo codigo
SMTP_ENCRYPTION=ssl
EMAIL_FROM_ADDRESS=noreply@seudominio.com.br
EMAIL_FROM_NAME=MovAmazon

# -----------------------------
# Admin (fallback .env)
# -----------------------------
ADMIN_EMAIL=admin@seudominio.com.br
# Preferir hash em vez de senha plana
ADMIN_PASSWORD_HASH=
# Fallback legado (evitar usar em producao)
ADMIN_PASSWORD=

# -----------------------------
# Mercado Pago / Mercado Livre
# -----------------------------
# Chaves principais (obrigatorias)
APP_Acess_token=APP_USR_xxx
APP_Public_Key=APP_USR_xxx

# Alias de compatibilidade (opcional)
APP_Access_token=
ML_ACCESS_TOKEN_PROD=
ML_PUBLIC_KEY_PROD=

# Webhook / retorno
ML_NOTIFICATION_URL=https://movamazon.com.br/api/mercadolivre/webhook.php
ML_AUTO_RETURN=https://movamazon.com.br/inscricao/sucesso
ML_WEBHOOK_SECRET=change_me_webhook_secret
# Alias legado opcional
Webhook_Secret=

# Itens e checkout (opcionais)
ML_EXTERNAL_REFERENCE=MOVAMAZON_
ML_STATEMENT_DESCRIPTOR=MOVAMAZON
ML_ITEM_TITLE=Inscricao MovAmazon
ML_ITEM_DESCRIPTION=Inscricao confirmada no MovAmazon
ML_ITEM_PICTURE_URL=https://movamazon.com.br/frontend/assets/img/logo.png
ML_ITEM_CATEGORY=EBL-Evento Desportivo

# Diagnostico opcional
ML_APP_ID=
MP_APP_ID=

# -----------------------------
# OpenAI (modulos de treino/IA)
# -----------------------------
OPENAI_API_KEY=

# -----------------------------
# Seguranca e cron (opcionais)
# -----------------------------
# Exemplo: https://app.movamazon.com.br,https://movamazon.com.br
CORS_ALLOWED_DOMAINS=
CANCELAR_INSCRICOES_TOKEN=change_me_long_random_token
CONFIG_CRYPT_KEY=change_me_32_plus_chars

# -----------------------------
# Legado (evitar usar)
# -----------------------------
Client_ID=
Client_Secret=
test_Public_Key=
test_Acess_token=
