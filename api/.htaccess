# Permitir acesso a arquivos PHP sem extensão
RewriteEngine On

# Se a requisição não termina com .php e não é um arquivo/diretório existente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Se o arquivo .php existe, redirecionar para ele
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Permitir acesso direto a arquivos PHP
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        <IfModule mod_access_compat.c>
            Order allow,deny
            Allow from all
        </IfModule>
    </IfModule>
</FilesMatch>
