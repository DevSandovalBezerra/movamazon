{
    "name": "acer/movamazon",
    "autoload": {
        "psr-4": {
            "Acer\\Movamazon\\": "src/"
        }
    },
    "authors": [
        {
            "name": "DevSandovalBezerra",
            "email": "devsandovalbezerra@gmail.com"
        }
    ],
    "require": {
        "mercadopago/dx-php": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.10",
        "intervention/image": "^3.11",
        "endroid/qr-code": "4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.55"
    },
    "scripts": {
        "test": "phpunit --testsuite Unit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration --bootstrap tests/bootstrap.integration.php",
        "test:all": "phpunit",
        "test:coverage": "phpdbg -qrr vendor/bin/phpunit --testsuite Unit --coverage-text --coverage-clover build/logs/clover.xml"
    }
}
